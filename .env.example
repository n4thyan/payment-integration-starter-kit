# Server
PORT=4242
APP_BASE_URL=http://localhost:4242
NODE_ENV=development

# Local demo checkout
# Keep this enabled when you want to test the full widget flow without provider accounts.
DEMO_CHECKOUT_ENABLED=true

# Stripe test mode
# Use a Stripe secret test key. Do not commit real keys.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_CURRENCY=gbp

# PayPal sandbox
# The client ID is safe to expose to the browser, but keep the secret server-side only.
PAYPAL_CLIENT_ID=replace_me
PAYPAL_CLIENT_SECRET=replace_me
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_CURRENCY=GBP
